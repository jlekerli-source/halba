# Optional. Proof Mode runs the recorded public fixture without credentials.
OPENAI_API_KEY=

# Optional runtime overrides.
PORT=4177
HALBA_HOST=127.0.0.1
HALBA_PROOF_BUNDLE=data/demo/bundle.json
HALBA_RECORDED_PROOF=data/demo/recorded/gpt-5.6-sol-proof.json
HALBA_STATE_FILE=.halba/halba.sqlite

# Non-loopback binding is refused unless explicitly enabled. When enabled,
# list every browser origin allowed to make state-changing API requests.
HALBA_ALLOW_REMOTE=0
HALBA_ALLOWED_ORIGINS=
